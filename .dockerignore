# ============================================================
# Git (repo + submodules)
# ============================================================
.git/
.gitattributes
.gitignore
.gitmodules
.github/
third_party/**/.git/

# ============================================================
# Python bytecode & packaging
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
dist/
build/
*.whl

# ============================================================
# Model weights — downloaded at runtime from ModelScope
# ============================================================
pretrained_models/
pretrained_models/*.pt
pretrained_models/*.pth
pretrained_models/*.safetensors
pretrained_models/*.bin
pretrained_models/*.onnx
pretrained_models/*.plan
pretrained_models/*.engine
*.safetensors
*.bin
*.onnx
*.plan
*.engine

# ============================================================
# Training artifacts
# ============================================================
exp/
data/
raw_wav/
tensorboard/
logs/
*.log

# ============================================================
# Audio files (except asset/)
# ============================================================
*.wav
*.m4a
*.aac
*.mp3
*.flac
*.ogg
!asset/

# ============================================================
# Archives
# ============================================================
*.tar
*.tar.gz
*.tgz
*.zip
*.7z
*.rar

