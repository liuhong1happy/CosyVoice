*.sublime-project
*.swn
*.swo
*.swp
*.swm
*~

# ============================================================
# OS files
# ============================================================
.DS_Store
Thumbs.db
Desktop.ini

# ============================================================
# Docker
# ============================================================
docker/
Dockerfile*
.dockerignore
docker-compose*.yml
.docker/

# ============================================================
# Docs (keep them tiny anyway, but exclude to be safe)
# ============================================================
CODE_OF_CONDUCT.md
FAQ.md

# ============================================================
# Dev tools & examples (not needed at runtime)
# ============================================================
tools/
webui.py
example.py

# ============================================================
